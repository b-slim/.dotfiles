#!/bin/bash
# Deploy Neovim and tmux configs to remote Linux VMs
# Usage:
#   deploy-dotfiles host1 host2 host3
#   deploy-dotfiles user@host1 user@host2

set -euo pipefail

DOTFILES_DIR="$HOME/.dotfiles"
NVIM_CONFIG="$DOTFILES_DIR/nvim_init.lua"
TMUX_CONFIG="$DOTFILES_DIR/tmux.conf"
ZSHRC="$DOTFILES_DIR/zshrc"
STARSHIP_CONFIG="$DOTFILES_DIR/starship.toml"
BASH_PROFILE_SNIPPET="$DOTFILES_DIR/bash_profile_snippet"
CLAUDE_STATUSLINE="$DOTFILES_DIR/statusline-command.sh"
CLAUDE_SETTINGS="$DOTFILES_DIR/claude-settings.json"

if [ $# -eq 0 ]; then
  echo "Usage: $0 <host1> [host2] [host3] ..."
  echo "Example: $0 user@vm1 user@vm2"
  exit 1
fi

for host in "$@"; do
  echo "--- Deploying to $host ---"

  # Install mosh-server if missing (detects package manager)
  ssh "$host" '
    if command -v mosh-server >/dev/null 2>&1; then
      echo "  mosh-server already installed"
    elif command -v tdnf >/dev/null 2>&1 && sudo -n tdnf install -y mosh 2>/dev/null; then
      echo "  mosh installed via tdnf"
    elif command -v dnf >/dev/null 2>&1 && sudo -n dnf install -y mosh 2>/dev/null; then
      echo "  mosh installed via dnf"
    elif command -v apt-get >/dev/null 2>&1 && sudo -n apt-get install -y mosh 2>/dev/null; then
      echo "  mosh installed via apt-get"
    else
      echo "  Warning: could not install mosh-server (no sudo or unsupported package manager)"
      echo "  To install manually: sudo tdnf install mosh"
    fi
  '

  # Update Neovim if missing or version < 0.8.0
  ssh "$host" '
    need_update=false
    if ! command -v nvim >/dev/null 2>&1; then
      echo "  Neovim not found, installing..."
      need_update=true
    else
      nvim_version=$(nvim --version | head -1 | grep -oE "[0-9]+\.[0-9]+\.[0-9]+")
      major=$(echo "$nvim_version" | cut -d. -f1)
      minor=$(echo "$nvim_version" | cut -d. -f2)
      if [ "$major" -lt 1 ] && [ "$minor" -lt 8 ]; then
        echo "  Neovim $nvim_version is below 0.8.0, updating..."
        need_update=true
      else
        echo "  Neovim $nvim_version is sufficient"
      fi
    fi
    if [ "$need_update" = true ]; then
      curl -LO https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
      rm -rf ~/.local/nvim-linux-x86_64
      mkdir -p ~/.local
      tar -C ~/.local -xzf nvim-linux-x86_64.tar.gz
      rm -f nvim-linux-x86_64.tar.gz
      if ! grep -q "/.local/nvim-linux-x86_64/bin" ~/.bashrc 2>/dev/null; then
        echo "export PATH=\"\$HOME/.local/nvim-linux-x86_64/bin:\$PATH\"" >> ~/.bashrc
      fi
      export PATH="$HOME/.local/nvim-linux-x86_64/bin:$PATH"
      echo "  Neovim updated to $(nvim --version | head -1)"
    fi
  '

  # Install zsh + plugins
  ssh "$host" '
    # Install zsh
    if command -v zsh >/dev/null 2>&1; then
      echo "  zsh already installed: $(zsh --version | head -1)"
    elif command -v tdnf >/dev/null 2>&1 && sudo -n tdnf install -y zsh 2>/dev/null; then
      echo "  zsh installed via tdnf"
    elif command -v dnf >/dev/null 2>&1 && sudo -n dnf install -y zsh 2>/dev/null; then
      echo "  zsh installed via dnf"
    elif command -v apt-get >/dev/null 2>&1 && sudo -n apt-get install -y zsh 2>/dev/null; then
      echo "  zsh installed via apt-get"
    else
      echo "  Warning: could not install zsh"
    fi

    # Install zsh-autosuggestions
    if [ ! -d "$HOME/.zsh/zsh-autosuggestions" ]; then
      mkdir -p "$HOME/.zsh"
      git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions \
        "$HOME/.zsh/zsh-autosuggestions" --quiet \
        && echo "  zsh-autosuggestions installed" || echo "  Warning: zsh-autosuggestions install failed"
    else
      echo "  zsh-autosuggestions already installed"
    fi

    # Install zsh-syntax-highlighting
    if [ ! -d "$HOME/.zsh/zsh-syntax-highlighting" ]; then
      git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting \
        "$HOME/.zsh/zsh-syntax-highlighting" --quiet \
        && echo "  zsh-syntax-highlighting installed" || echo "  Warning: zsh-syntax-highlighting install failed"
    else
      echo "  zsh-syntax-highlighting already installed"
    fi

    # Install zoxide
    if command -v zoxide >/dev/null 2>&1; then
      echo "  zoxide already installed"
    else
      curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh 2>/dev/null \
        && echo "  zoxide installed" || echo "  Warning: zoxide install failed"
    fi

    # Install starship (prompt)
    if command -v starship >/dev/null 2>&1; then
      echo "  starship already installed"
    else
      mkdir -p "$HOME/.local/bin"
      curl -sS https://starship.rs/install.sh | sh -s -- -y -b "$HOME/.local/bin" >/dev/null 2>&1 \
        && echo "  starship installed" || echo "  Warning: starship install failed"
    fi

    # Install modern CLI tools (eza, bat, fd, ripgrep, fzf) from GitHub release
    # tarballs into ~/.local/bin — no sudo required. Linux x86_64 only for now.
    gh_latest_tag() {
      curl -sI "https://github.com/$1/releases/latest" \
        | awk -F/ "tolower(\$0) ~ /^location:/ {gsub(/[\r\n]/,\"\",\$NF); print \$NF}"
    }
    install_bin_from_tar() {
      local url="$1" bin_name="$2" tmp found
      mkdir -p "$HOME/.local/bin"
      tmp=$(mktemp -d) || return 1
      if ! curl -sSLf "$url" -o "$tmp/pkg.tgz" 2>/dev/null; then
        rm -rf "$tmp"; return 1
      fi
      tar -C "$tmp" -xzf "$tmp/pkg.tgz" 2>/dev/null || { rm -rf "$tmp"; return 1; }
      found=$(find "$tmp" -type f -name "$bin_name" 2>/dev/null | head -1)
      if [ -z "$found" ]; then
        rm -rf "$tmp"; return 1
      fi
      cp "$found" "$HOME/.local/bin/$bin_name"
      chmod +x "$HOME/.local/bin/$bin_name"
      rm -rf "$tmp"
      return 0
    }
    try_install() {
      local bin_name="$1" url="$2"
      if command -v "$bin_name" >/dev/null 2>&1; then
        echo "  $bin_name already installed"
      elif install_bin_from_tar "$url" "$bin_name"; then
        echo "  $bin_name installed (binary)"
      else
        echo "  Warning: $bin_name install failed"
      fi
    }

    if [ "$(uname -s)" = "Linux" ] && [ "$(uname -m)" = "x86_64" ]; then
      # eza — asset filename has no version, use /latest/download/
      try_install eza \
        "https://github.com/eza-community/eza/releases/latest/download/eza_x86_64-unknown-linux-gnu.tar.gz"

      # bat, fd — tags like v0.24.0, filename embeds tag
      v=$(gh_latest_tag sharkdp/bat)
      try_install bat \
        "https://github.com/sharkdp/bat/releases/download/${v}/bat-${v}-x86_64-unknown-linux-gnu.tar.gz"
      v=$(gh_latest_tag sharkdp/fd)
      try_install fd \
        "https://github.com/sharkdp/fd/releases/download/${v}/fd-${v}-x86_64-unknown-linux-gnu.tar.gz"

      # ripgrep — tag has no "v" prefix (e.g. 14.1.0), musl for portability
      v=$(gh_latest_tag BurntSushi/ripgrep)
      try_install rg \
        "https://github.com/BurntSushi/ripgrep/releases/download/${v}/ripgrep-${v}-x86_64-unknown-linux-musl.tar.gz"

      # fzf — tag v0.56.3, filename uses version without "v"
      v=$(gh_latest_tag junegunn/fzf)
      try_install fzf \
        "https://github.com/junegunn/fzf/releases/download/${v}/fzf-${v#v}-linux_amd64.tar.gz"

      # async-profiler — bundles jfrconv. The jfrconv launcher is a shell
      # script that needs its sibling jar, so extract the full archive into
      # ~/.local/async-profiler and symlink jfrconv + asprof into ~/.local/bin.
      if command -v jfrconv >/dev/null 2>&1; then
        echo "  jfrconv already installed"
      else
        v=$(gh_latest_tag async-profiler/async-profiler)
        if [ -n "$v" ]; then
          ver=${v#v}
          url="https://github.com/async-profiler/async-profiler/releases/download/${v}/async-profiler-${ver}-linux-x64.tar.gz"
          tmp=$(mktemp -d)
          if curl -sSLf "$url" -o "$tmp/ap.tgz" 2>/dev/null \
             && tar -C "$tmp" -xzf "$tmp/ap.tgz" 2>/dev/null; then
            ap_dir=$(find "$tmp" -maxdepth 1 -type d -name "async-profiler-*" | head -1)
            if [ -n "$ap_dir" ]; then
              rm -rf "$HOME/.local/async-profiler"
              mv "$ap_dir" "$HOME/.local/async-profiler"
              ln -sf "$HOME/.local/async-profiler/bin/jfrconv" "$HOME/.local/bin/jfrconv"
              ln -sf "$HOME/.local/async-profiler/bin/asprof" "$HOME/.local/bin/asprof"
              echo "  jfrconv installed (async-profiler ${ver})"
            else
              echo "  Warning: jfrconv install failed (no extract dir)"
            fi
          else
            echo "  Warning: jfrconv install failed (download/extract)"
          fi
          rm -rf "$tmp"
        else
          echo "  Warning: jfrconv install failed (could not fetch latest tag)"
        fi
      fi
    else
      echo "  Note: skipping binary installers (not Linux x86_64)"
    fi

    # Note: we do not run chsh — LDAP-backed users cannot change their login
    # shell locally, and chsh often hangs waiting for a password. Instead we
    # patch ~/.bash_profile below to exec zsh on interactive login, and
    # tmux.conf sets default-shell to zsh so nested sessions also land in zsh.
  '

  # Deploy zshrc
  if [ -f "$ZSHRC" ]; then
    cat "$ZSHRC" | ssh "$host" "cat > ~/.zshrc"
    echo "  zshrc deployed"
  fi

  # Patch ~/.bash_profile to auto-exec into zsh on interactive login
  # (idempotent — guarded by the "dotfiles-auto-exec-zsh" marker).
  if [ -f "$BASH_PROFILE_SNIPPET" ]; then
    cat "$BASH_PROFILE_SNIPPET" | ssh "$host" '
      snippet=$(cat)
      if [ ! -f ~/.bash_profile ] || ! grep -q "dotfiles-auto-exec-zsh" ~/.bash_profile; then
        printf "\n%s\n" "$snippet" >> ~/.bash_profile
        echo "  bash_profile patched to auto-exec zsh"
      else
        echo "  bash_profile already configured to auto-exec zsh"
      fi
    '
  fi

  # Deploy starship config
  if [ -f "$STARSHIP_CONFIG" ]; then
    ssh "$host" "mkdir -p ~/.config"
    cat "$STARSHIP_CONFIG" | ssh "$host" "cat > ~/.config/starship.toml"
    echo "  starship.toml deployed"
  fi

  # Copy configs via SSH pipe (handles hostnames with / like trino-deployer/freezing-silicon)
  ssh "$host" "mkdir -p ~/.config/nvim"
  cat "$NVIM_CONFIG" | ssh "$host" "cat > ~/.config/nvim/init.lua"

  # Copy tmux config
  if [ -f "$TMUX_CONFIG" ]; then
    cat "$TMUX_CONFIG" | ssh "$host" "cat > ~/.tmux.conf"
    ssh "$host" 'tmux source-file ~/.tmux.conf 2>/dev/null || echo "  Note: tmux not running, config will apply on next session"'

    # Install TPM and plugins on remote
    ssh "$host" '
      if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
        echo "  Installing TPM..."
        git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm" --depth=1 --quiet \
          && echo "  TPM installed"
      else
        echo "  TPM already installed"
      fi
      "$HOME/.tmux/plugins/tpm/bin/install_plugins" 2>/dev/null \
        && echo "  Tmux plugins installed" \
        || echo "  Note: open tmux and press Prefix+I to install plugins manually"
    '
  fi

  # Copy Claude statusline
  if [ -f "$CLAUDE_STATUSLINE" ]; then
    ssh "$host" "mkdir -p ~/.claude"
    cat "$CLAUDE_STATUSLINE" | ssh "$host" "cat > ~/.claude/statusline-command.sh && chmod +x ~/.claude/statusline-command.sh"
    # Merge settings (statusline + permissions) into existing settings.json
    if [ -f "$CLAUDE_SETTINGS" ]; then
      # Encode settings as a single-line JSON string to pass via ssh command
      incoming=$(cat "$CLAUDE_SETTINGS" | tr -d '\n')
      ssh "$host" "
        if [ ! -f ~/.claude/settings.json ]; then
          echo '{}' > ~/.claude/settings.json
        fi
        if command -v jq >/dev/null 2>&1; then
          tmp=\$(jq --argjson incoming '$incoming' '. * \$incoming' ~/.claude/settings.json)
          echo \"\$tmp\" > ~/.claude/settings.json
        else
          echo '  Warning: jq not found, cannot merge settings'
        fi
      "
    fi
  fi

  # Install Ghostty terminfo if available locally
  if infocmp -x xterm-ghostty >/dev/null 2>&1; then
    infocmp -x xterm-ghostty | ssh "$host" 'tic -x - 2>/dev/null && echo "  Installed xterm-ghostty terminfo" || echo "  Warning: could not install terminfo (tic not found)"'
  fi

  # Headless plugin install on remote
  ssh "$host" 'nvim --headless "+Lazy! sync" +qa 2>/dev/null || echo "  Note: run nvim manually to install plugins"'

  echo "  Done: $host"
done

echo "--- All hosts deployed ---"
