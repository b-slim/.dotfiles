#!/bin/bash
# Deploy Neovim, tmux, zsh, git, Ghostty, and Claude configs to local macOS
# Usage:
#   deploy-dotfiles-local [--copy] [--dry-run] [--macos-defaults]
#
# By default, configs are symlinked so `git pull` auto-updates them.
# Use --copy to copy files instead (useful if you want to edit independently).
# Use --dry-run to preview all actions without making any changes.
# Use --macos-defaults to also apply macOS system settings (keyboard, Dock, Finder, etc.).

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source files
NVIM_CONFIG="$DOTFILES_DIR/nvim_init.lua"
TMUX_CONFIG="$DOTFILES_DIR/tmux.conf"
ZSHRC="$DOTFILES_DIR/zshrc"
STARSHIP_CONFIG="$DOTFILES_DIR/starship.toml"
GHOSTTY_CONFIG="$DOTFILES_DIR/ghostty.conf"
GITCONFIG="$DOTFILES_DIR/gitconfig"
GITCONFIG_LOCAL="$DOTFILES_DIR/gitconfig.local"
GITCONFIG_PERSONAL="$DOTFILES_DIR/gitconfig.personal"
SSH_CONFIG_CUSTOM="$DOTFILES_DIR/ssh_config.custom"
GITIGNORE_GLOBAL="$DOTFILES_DIR/gitignore_global"
CLAUDE_STATUSLINE="$DOTFILES_DIR/statusline-command.sh"
CLAUDE_SETTINGS="$DOTFILES_DIR/claude-settings.json"
BREWFILE="$DOTFILES_DIR/Brewfile"
MACOS_DEFAULTS="$DOTFILES_DIR/macos-defaults.sh"

USE_SYMLINKS=true
DRY_RUN=false
RUN_MACOS_DEFAULTS=false

for arg in "$@"; do
  case "$arg" in
    --copy)           USE_SYMLINKS=false ;;
    --dry-run)        DRY_RUN=true ;;
    --macos-defaults) RUN_MACOS_DEFAULTS=true ;;
    --help|-h)
      echo "Usage: $0 [--copy] [--dry-run] [--macos-defaults]"
      echo ""
      echo "Deploys Neovim, tmux, zsh, git, Ghostty, and Claude Code configs to the local macOS machine."
      echo ""
      echo "Options:"
      echo "  --copy           Copy files instead of symlinking (default: symlink)"
      echo "  --dry-run        Preview all actions without making any changes"
      echo "  --macos-defaults Also apply macOS system settings (keyboard, Dock, Finder, etc.)"
      echo "  --help           Show this help"
      echo ""
      echo "Symlinks (default) keep configs in sync with git pull automatically."
      exit 0
      ;;
    *)
      echo "Unknown option: $arg"
      echo "Run '$0 --help' for usage."
      exit 1
      ;;
  esac
done

# ── Helpers ──────────────────────────────────────────────────────────────────

info()    { echo "  $*"; }
success() { echo "  ✓ $*"; }
warn()    { echo "  ⚠ $*"; }
dryrun()  { echo "  [dry-run] $*"; }

# run CMD [ARGS...] — executes command, or prints it in dry-run mode
run() {
  if [ "$DRY_RUN" = true ]; then
    dryrun "$*"
  else
    "$@"
  fi
}

# deploy_file SRC DST — symlink or copy SRC to DST, backing up existing regular files
deploy_file() {
  local src="$1"
  local dst="$2"
  local dst_dir
  dst_dir="$(dirname "$dst")"

  run mkdir -p "$dst_dir"

  # Back up existing file if it's a regular file (not already a symlink to us)
  if [ -f "$dst" ] && [ ! -L "$dst" ]; then
    if [ "$DRY_RUN" = true ]; then
      dryrun "backup existing $dst → $dst.bak"
    else
      cp "$dst" "$dst.bak"
      info "Backed up existing $(basename "$dst") → $dst.bak"
    fi
  fi

  if [ "$USE_SYMLINKS" = true ]; then
    run ln -sf "$src" "$dst"
    success "Symlink $(basename "$dst") → $src"
  else
    run cp "$src" "$dst"
    success "Copied $(basename "$src") → $dst"
  fi
}

# ── macOS check ───────────────────────────────────────────────────────────────

if [ "$(uname)" != "Darwin" ]; then
  echo "Error: this script is for macOS only."
  echo "For remote Linux VMs, use: deploy-dotfiles user@host"
  exit 1
fi

echo "--- Deploying dotfiles to local macOS ---"

# ── Homebrew ──────────────────────────────────────────────────────────────────

echo ""
echo "Homebrew..."
if ! command -v brew >/dev/null 2>&1; then
  if [ "$DRY_RUN" = true ]; then
    dryrun "Homebrew not found — would install via https://brew.sh"
  else
    echo "  Homebrew is not installed. Installing now..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [ -f /opt/homebrew/bin/brew ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    fi
  fi
else
  success "Homebrew found: $(brew --version | head -1)"
fi

# ── Brewfile: install all packages at once ────────────────────────────────────

echo ""
echo "Installing packages from Brewfile..."
if [ ! -f "$BREWFILE" ]; then
  warn "Brewfile not found in $DOTFILES_DIR, skipping"
else
  if [ "$DRY_RUN" = true ]; then
    dryrun "brew bundle --file=$BREWFILE --no-upgrade"
  else
    brew bundle --file="$BREWFILE" --no-upgrade || warn "Some Brewfile packages failed to install"
    success "Brewfile packages installed"
  fi
fi

# Ensure critical tools are available (fallback if brew bundle was skipped)
install_if_missing() {
  local cmd="$1"
  local pkg="${2:-$1}"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    if [ "$DRY_RUN" = true ]; then
      dryrun "$cmd not found — would run: brew install $pkg"
    else
      info "Installing $pkg via Homebrew..."
      brew install "$pkg"
      success "$pkg installed"
    fi
  fi
}
install_if_missing nvim neovim
install_if_missing jq jq

# ── Zsh config ────────────────────────────────────────────────────────────────

echo ""
echo "Deploying zsh config..."
if [ ! -f "$ZSHRC" ]; then
  warn "zshrc not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$ZSHRC" "$HOME/.zshrc"
fi

# ── Starship prompt ───────────────────────────────────────────────────────────

echo ""
echo "Deploying Starship config..."
if [ ! -f "$STARSHIP_CONFIG" ]; then
  warn "starship.toml not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$STARSHIP_CONFIG" "$HOME/.config/starship.toml"
fi

# ── Ghostty config ────────────────────────────────────────────────────────────

echo ""
echo "Deploying Ghostty config..."
if [ ! -f "$GHOSTTY_CONFIG" ]; then
  warn "ghostty.conf not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$GHOSTTY_CONFIG" "$HOME/.config/ghostty/config"
fi

# ── Git config ────────────────────────────────────────────────────────────────

echo ""
echo "Deploying git config..."
if [ ! -f "$GITCONFIG" ]; then
  warn "gitconfig not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$GITCONFIG" "$HOME/.gitconfig"
fi

if [ ! -f "$GITIGNORE_GLOBAL" ]; then
  warn "gitignore_global not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$GITIGNORE_GLOBAL" "$HOME/.gitignore_global"
fi

# Deploy git identities
if [ -f "$GITCONFIG_LOCAL" ]; then
  deploy_file "$GITCONFIG_LOCAL" "$HOME/.gitconfig.local"
fi
if [ -f "$GITCONFIG_PERSONAL" ]; then
  deploy_file "$GITCONFIG_PERSONAL" "$HOME/.gitconfig.personal"
  run mkdir -p "$HOME/perso"
  info "~/perso/ created — repos cloned there will use bslim@apache.org"
fi

# ── SSH custom config ─────────────────────────────────────────────────────────

echo ""
echo "Deploying SSH custom config..."
if [ ! -f "$SSH_CONFIG_CUSTOM" ]; then
  warn "ssh_config.custom not found in $DOTFILES_DIR, skipping"
else
  run mkdir -p "$HOME/.ssh"
  deploy_file "$SSH_CONFIG_CUSTOM" "$HOME/.ssh/config.custom"
  run chmod 600 "$HOME/.ssh/config.custom"
fi

# ── jenv setup ────────────────────────────────────────────────────────────────

echo ""
echo "Setting up jenv..."
if ! command -v jenv >/dev/null 2>&1; then
  warn "jenv not found, skipping (run brew bundle first)"
else
  # Enable essential plugins
  for plugin in export maven gradle; do
    if [ "$DRY_RUN" = true ]; then
      dryrun "jenv enable-plugin $plugin"
    else
      jenv enable-plugin "$plugin" 2>/dev/null && success "jenv plugin: $plugin" || true
    fi
  done

  # Auto-discover and register all installed JDKs
  for jdk_home in /Library/Java/JavaVirtualMachines/*/Contents/Home; do
    if [ -d "$jdk_home" ]; then
      if [ "$DRY_RUN" = true ]; then
        dryrun "jenv add $jdk_home"
      else
        jenv add "$jdk_home" 2>/dev/null && success "jenv: registered $jdk_home" || true
      fi
    fi
  done

  # Set global default to latest registered version if none set
  if [ "$DRY_RUN" = false ]; then
    current=$(jenv global 2>/dev/null)
    if [ "$current" = "system" ] || [ -z "$current" ]; then
      latest=$(jenv versions --bare 2>/dev/null | grep -v "^system" | sort -V | tail -1)
      if [ -n "$latest" ]; then
        jenv global "$latest" && success "jenv global set to $latest"
      fi
    else
      success "jenv global: $current"
    fi
  fi
fi

# ── Neovim config ─────────────────────────────────────────────────────────────

echo ""
echo "Deploying Neovim config..."
if [ ! -f "$NVIM_CONFIG" ]; then
  warn "nvim_init.lua not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$NVIM_CONFIG" "$HOME/.config/nvim/init.lua"
fi

# ── Tmux config ───────────────────────────────────────────────────────────────

echo ""
echo "Deploying tmux config..."
if [ ! -f "$TMUX_CONFIG" ]; then
  warn "tmux.conf not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$TMUX_CONFIG" "$HOME/.tmux.conf"
  if tmux info >/dev/null 2>&1; then
    if [ "$DRY_RUN" = true ]; then
      dryrun "tmux source-file ~/.tmux.conf"
    else
      tmux source-file "$HOME/.tmux.conf" 2>/dev/null && success "Tmux config reloaded" || warn "Could not reload tmux config"
    fi
  else
    info "Tmux not running — config will apply on next session"
  fi
fi

# ── Claude Code statusline ────────────────────────────────────────────────────

echo ""
echo "Deploying Claude Code statusline..."
if [ ! -f "$CLAUDE_STATUSLINE" ]; then
  warn "statusline-command.sh not found in $DOTFILES_DIR, skipping"
else
  deploy_file "$CLAUDE_STATUSLINE" "$HOME/.claude/statusline-command.sh"
  run chmod +x "$HOME/.claude/statusline-command.sh"
fi

# ── Claude Code settings (always merged, never symlinked) ────────────────────

echo ""
echo "Merging Claude Code settings..."
if [ ! -f "$CLAUDE_SETTINGS" ]; then
  warn "claude-settings.json not found in $DOTFILES_DIR, skipping"
else
  run mkdir -p "$HOME/.claude"
  if [ "$DRY_RUN" = true ]; then
    dryrun "merge claude-settings.json into ~/.claude/settings.json (via jq '. * \$incoming')"
  else
    if [ ! -f "$HOME/.claude/settings.json" ]; then
      echo '{}' > "$HOME/.claude/settings.json"
      info "Created empty settings.json"
    fi
    if command -v jq >/dev/null 2>&1; then
      incoming=$(tr -d '\n' < "$CLAUDE_SETTINGS")
      tmp=$(jq --argjson incoming "$incoming" '. * $incoming' "$HOME/.claude/settings.json")
      echo "$tmp" > "$HOME/.claude/settings.json"
      success "Merged claude-settings.json into ~/.claude/settings.json"
    else
      warn "jq not found, cannot merge settings"
    fi
  fi
fi

# ── Neovim plugin install ─────────────────────────────────────────────────────

echo ""
echo "Installing Neovim plugins (headless)..."
if [ "$DRY_RUN" = true ]; then
  dryrun "nvim --headless \"+Lazy! sync\" +qa"
elif nvim --headless "+Lazy! sync" +qa 2>/dev/null; then
  success "Neovim plugins installed/updated"
else
  warn "Plugin auto-install failed — run nvim manually to install plugins"
fi

# ── macOS system defaults (opt-in) ────────────────────────────────────────────

if [ "$RUN_MACOS_DEFAULTS" = true ]; then
  echo ""
  echo "Applying macOS system defaults..."
  if [ ! -f "$MACOS_DEFAULTS" ]; then
    warn "macos-defaults.sh not found in $DOTFILES_DIR, skipping"
  elif [ "$DRY_RUN" = true ]; then
    dryrun "bash $MACOS_DEFAULTS"
  else
    bash "$MACOS_DEFAULTS"
  fi
fi

# ── Self-symlink in ~/bin ─────────────────────────────────────────────────────

echo ""
echo "Ensuring deploy scripts are in ~/bin..."
run mkdir -p "$HOME/bin"

for script in deploy-dotfiles deploy-dotfiles-local; do
  target="$DOTFILES_DIR/$script"
  link="$HOME/bin/$script"
  if [ -f "$target" ]; then
    run ln -sf "$target" "$link"
    success "~/bin/$script → $target"
  fi
done

# ── Done ──────────────────────────────────────────────────────────────────────

echo ""
echo "--- Done ---"
echo ""
echo "Next steps:"
echo "  • source ~/.zshrc  (or open a new terminal)"
echo "  • Launch nvim to verify config loaded"
echo "  • Clone personal repos under ~/perso/ to use bslim@apache.org automatically"
if [ "$RUN_MACOS_DEFAULTS" = false ]; then
  echo "  • Run 'deploy-dotfiles-local --macos-defaults' to apply keyboard/Dock/Finder settings"
fi
if [ "$USE_SYMLINKS" = true ]; then
  echo "  • Run 'git pull' in ~/.dotfiles to keep all configs up to date"
fi
